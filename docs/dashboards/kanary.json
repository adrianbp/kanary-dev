{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Kanary Operator — canary rollout status, reconciler health and analysis metrics.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["kanary", "operator", "canary"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kanary Operator",
  "uid": "kanary-operator-v1",
  "version": 1,

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(kanary_canary_phase, namespace)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "current": {}
      },
      {
        "name": "canary",
        "type": "query",
        "label": "Canary",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(kanary_canary_phase{namespace=~\"$namespace\"}, name)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "current": {}
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Active Canaries",
      "description": "Number of canaries currently in a non-Idle phase.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "count(kanary_canary_phase{namespace=~\"$namespace\", name=~\"$canary\", phase!=\"Idle\"} == 1) or vector(0)",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Promotions (24 h)",
      "description": "Total successful canary promotions in the last 24 hours.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(kanary_canary_promotions_total{namespace=~\"$namespace\"}[24h])) or vector(0)",
          "legendFormat": "promotions",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Rollbacks (24 h)",
      "description": "Total canary rollbacks in the last 24 hours.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(kanary_canary_rollbacks_total{namespace=~\"$namespace\"}[24h])) or vector(0)",
          "legendFormat": "rollbacks",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Reconcile p95 Latency",
      "description": "95th-percentile reconcile call duration.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(kanary_reconcile_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "table",
      "title": "Canary Status",
      "description": "Current phase and traffic weight for every tracked canary.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Namespace", "desc": false }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Phase" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Idle":              { "color": "grey",       "index": 0 } } },
                  { "type": "value", "options": { "Progressing":       { "color": "blue",       "index": 1 } } },
                  { "type": "value", "options": { "Analyzing":         { "color": "purple",     "index": 2 } } },
                  { "type": "value", "options": { "AwaitingPromotion": { "color": "yellow",     "index": 3 } } },
                  { "type": "value", "options": { "Succeeded":         { "color": "green",      "index": 4 } } },
                  { "type": "value", "options": { "RolledBack":        { "color": "orange",     "index": 5 } } },
                  { "type": "value", "options": { "Failed":            { "color": "red",        "index": 6 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Weight (%)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.displayMode", "value": "lcd-gauge" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByLabels",
          "options": { "value": "phase" }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "name": "Name",
              "phase": "Phase"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "kanary_canary_phase{namespace=~\"$namespace\", name=~\"$canary\"} == 1",
          "legendFormat": "{{namespace}} / {{name}} — {{phase}}",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "kanary_canary_step_weight{namespace=~\"$namespace\", name=~\"$canary\"}",
          "legendFormat": "{{namespace}} / {{name}}",
          "instant": true,
          "format": "table",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Canary Traffic Weight",
      "description": "Current traffic weight routed to the canary version over time.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "kanary_canary_step_weight{namespace=~\"$namespace\", name=~\"$canary\"}",
          "legendFormat": "{{namespace}}/{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Reconcile Duration",
      "description": "Reconcile call latency percentiles.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(kanary_reconcile_duration_seconds_bucket[2m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(kanary_reconcile_duration_seconds_bucket[2m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(kanary_reconcile_duration_seconds_bucket[2m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Analysis Checks",
      "description": "Rate of metric checks performed by the analysis engine, split by outcome.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(kanary_analysis_checks_total{namespace=~\"$namespace\", passed=\"true\"}[2m]))",
          "legendFormat": "passed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kanary_analysis_checks_total{namespace=~\"$namespace\", passed=\"false\"}[2m]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Provider Errors",
      "description": "Rate of metric provider errors by provider type.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (provider, kind) (rate(kanary_provider_errors_total{namespace=~\"$namespace\"}[2m]))",
          "legendFormat": "{{provider}} / {{kind}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Promotions & Rollbacks Rate",
      "description": "Rate of canary promotions and rollbacks over time.",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "promotions" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rollbacks" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(kanary_canary_promotions_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "promotions",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kanary_canary_rollbacks_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "rollbacks",
          "refId": "B"
        }
      ]
    }

  ]
}
